{
  "firestore": {
    "rules": "firestore.rules"
  },
  "hosting": {
    "site": "machub",
    "public": ".",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**",
      "machub-app/**",
      "machin_backend/**",
      "workers/**",
      "data/**",
      "docs/**",
      "option_b/**",
      "scratch/**",
      "node_modules/**",
      "package.json",
      "package-lock.json",
      "server.js",
      "batch_scrape.py",
      "script.js",
      "README.md",
      "KNOWLEAGE.txt",
      "*.py",
      "*.json",
      "*.log",
      "*.html.bak",
      "students.json",
      "sync_test.json",
      "portal_specs.json",
      "browser_discovery.json",
      "render.yaml"
    ],
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  },
  "functions": {
    "source": "machin_backend",
    "runtime": "python310"
  }
}
