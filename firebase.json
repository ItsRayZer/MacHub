{
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "hosting": {
    "site": "machub",
    "public": ".",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**",
      "machub-app/**",
      "machin_backend/**",
      "workers/**",
      "functions/**",
      "docs/**",
      "option_b/**",
      "scratch/**",
      "tools/**",
      "node_modules/**",
      "package.json",
      "package-lock.json",
      "server.js",
      "batch_scrape.py",
      "script.js",
      "README.md",
      "KNOWLEAGE.txt",
      "render.yaml",
      "students.json",
      "students_all.json",
      "sync_errors.json",
      "sync_test.json",
      "portal_specs.json",
      "browser_discovery.json",
      "firestore.indexes.json",
      "*.py",
      "*.log",
      "*.html.bak"
    ],
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  },
  "functions": [
    {
      "source": "functions",
      "codebase": "machub-functions",
      "runtime": "nodejs18",
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log"
      ]
    }
  ]
}
