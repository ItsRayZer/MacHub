# ─── Machub Capture Configuration ───────────────────────────────────────────
# Copy this file to .env and fill in your values.

# Your Hugging Face Space URL (no trailing slash)
HF_SPACE_URL=https://mrrayzer-machub.hf.space

# API secret key (must match HF Space secret API_SECRET_KEY)
API_SECRET_KEY=your-secret-key-here

# Class division (BCA-A, BCA-B, BCA-C, MCA-A, MCA-B)
DIVISION=BCA-A

# Camera source: 0 = default webcam, 1 = second camera, or RTSP URL
CAMERA_SOURCE=0

# Seconds between frame uploads (minimum recommended: 5)
SCAN_INTERVAL=5
